/*
 * Pico balloon beacon — Arduino Nano + ATGM336H-5N (GNSS) + Si5351A
 *
 * - Acquire UTC time from GPS; optional Maidenhead grid from GPS position (RMC).
 * - Once per UTC day in a configurable morning window, transmit WSPR (4-FSK) on 10 m.
 *
 * Libraries (Arduino Library Manager):
 *   - Adafruit Si5351 Library (depends: Adafruit BusIO)
 *   - JTEncode (Etherkit)
 *
 * WSPR: ~110.6 s, 162 symbols, ~1.46 Hz tone spacing (Etherkit / Si5351JTDemo convention).
 * Dial frequency 10 m: 28.124600 MHz (adjust WSPR_BASE_HZ if your allocation differs).
 *
 * RF: Si5351 is a clock source; add filtering, PA, and antenna per regulations.
 */

#include <Arduino.h>
#include <EEPROM.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <SoftwareSerial.h>
#include <Wire.h>
#include <Adafruit_SI5351.h>
#include <JTEncode.h>

// ---------------------------------------------------------------------------
// User configuration
// ---------------------------------------------------------------------------

//If needed, change the frequency of the WSPR transmission here*/
/** WSPR dial frequency (Hz), 10 m segment. */
static const double WSPR_BASE_HZ = 14074000.0;

/** ITU-style dBm level for WSPR (must be one of the standard WSPR steps, e.g. 20, 23, …). */
static const int8_t WSPR_POWER_DBM = 20;

/** Callsign (WSPR type 1; library pads/validates). */
static const char CALLSIGN[] = "AK6OZ";

/** If GPS has no fix, use this 4-character Maidenhead (field + square). */
static const char GRID_STATIC[] = "CM97";

/** UTC hour window [start, end) for the daily transmit (end exclusive). */
static const uint8_t MORNING_START_UTC_HOUR = 6;
static const uint8_t MORNING_END_UTC_HOUR = 12;

static const int EEPROM_ADDR_LAST_TX_DAY = 0;

static const int PIN_GPS_RX = 4;
static const long GPS_BAUD = 9600;

/** Etherkit WSPR symbol period (ms); 8192/12000 s ≈ 682.67 ms. */
static const uint16_t WSPR_SYMBOL_DELAY_MS = 683;

/** Tone spacing: 146 = 1.46 Hz when using Etherkit set_freq (Hz*100) convention. */
static const uint8_t WSPR_TONE_SPACING_CENTIHZ = 146;

static const uint8_t DEBUG_FORCE_TX = 0;

// ---------------------------------------------------------------------------

Adafruit_SI5351 clockgen;
SoftwareSerial gpsSerial(PIN_GPS_RX, 5);
JTEncode jtencode;

static bool si5351Ok = false;

static uint8_t utcHour = 0, utcMinute = 0, utcSecond = 0;
static uint8_t utcDay = 1, utcMonth = 1;
static uint16_t utcYear = 2000;
static bool haveTime = false;

static float gpsLatDeg = 0.0f;
static float gpsLonDeg = 0.0f;
static bool havePosition = false;

// ---------------------------------------------------------------------------
// Si5351: PLLA = 900 MHz (25 MHz * 36), fractional multisynth for sub-Hz WSPR steps
// ---------------------------------------------------------------------------

static bool si5351SetClk0HzDouble(double hz) {
  if (!si5351Ok) return false;
  if (hz < 28000000.0 || hz > 29700000.0) return false;

  const double fVco = 900000000.0;
  uint64_t msNum = (uint64_t)(fVco * 1048575.0 / hz);
  uint32_t a = (uint32_t)(msNum / 1048575ULL);
  uint32_t b = (uint32_t)(msNum % 1048575ULL);
  const uint32_t c = 1048575UL;
  if (a < 4U) a = 4U;

  clockgen.setupPLLInt(SI5351_PLL_A, 36);
  clockgen.setupMultisynth(0, SI5351_PLL_A, a, b, c);
  clockgen.setupRdiv(0, SI5351_R_DIV_1);
  return true;
}

static double wsprSymbolToHz(uint8_t sym) {
  return WSPR_BASE_HZ + (double)sym * (double)WSPR_TONE_SPACING_CENTIHZ / 100.0;
}

static void sendWsprPacket(const char *call, const char *grid4, int8_t dbm) {
  uint8_t symbols[WSPR_SYMBOL_COUNT];
  memset(symbols, 0, sizeof(symbols));

  jtencode.wspr_encode(call, grid4, dbm, symbols);

  if (!si5351Ok) return;

  clockgen.enableOutputs(true);
  for (uint16_t i = 0; i < WSPR_SYMBOL_COUNT; i++) {
    (void)si5351SetClk0HzDouble(wsprSymbolToHz(symbols[i]));
    delay(WSPR_SYMBOL_DELAY_MS);
  }
  clockgen.enableOutputs(false);
}

// ---------------------------------------------------------------------------
// NMEA RMC: time, date, position
// ---------------------------------------------------------------------------

static float nmeaCoordToDegLat(const char *s, char hemi) {
  if (!s || strlen(s) < 4) return 0.0f;
  float v = (float)atof(s);
  int deg = (int)(v / 100.0f);
  float m = v - (float)(deg * 100);
  float dec = (float)deg + m / 60.0f;
  if (hemi == 'S' || hemi == 's') dec = -dec;
  return dec;
}

static float nmeaCoordToDegLon(const char *s, char hemi) {
  if (!s || strlen(s) < 4) return 0.0f;
  float v = (float)atof(s);
  int deg = (int)(v / 100.0f);
  float m = v - (float)(deg * 100);
  float dec = (float)deg + m / 60.0f;
  if (hemi == 'W' || hemi == 'w') dec = -dec;
  return dec;
}

static bool parseRMC(const char *line) {
  if (strncmp(line, "$GNRMC", 6) != 0 && strncmp(line, "$GPRMC", 6) != 0) return false;

  char tmp[100];
  strncpy(tmp, line, sizeof(tmp) - 1);
  tmp[sizeof(tmp) - 1] = '\0';

  char *star = strchr(tmp, '*');
  if (star) *star = '\0';

  char *tok = strtok(tmp, ",");
  int field = 0;

  utcHour = utcMinute = utcSecond = 0;
  bool gotTime = false, gotDate = false;
  char status = 'V';
  char latStr[16] = "";
  char lonStr[16] = "";
  char hemiNs = 'N';
  char hemiEw = 'E';

  while (tok) {
    if (field == 1 && strlen(tok) >= 6) {
      utcHour = (uint8_t)((tok[0] - '0') * 10 + (tok[1] - '0'));
      utcMinute = (uint8_t)((tok[2] - '0') * 10 + (tok[3] - '0'));
      utcSecond = (uint8_t)((tok[4] - '0') * 10 + (tok[5] - '0'));
      gotTime = true;
    } else if (field == 2 && strlen(tok) >= 1) {
      status = tok[0];
    } else if (field == 3 && strlen(tok) > 0) {
      strncpy(latStr, tok, sizeof(latStr) - 1);
    } else if (field == 4 && strlen(tok) >= 1) {
      hemiNs = tok[0];
    } else if (field == 5 && strlen(tok) > 0) {
      strncpy(lonStr, tok, sizeof(lonStr) - 1);
    } else if (field == 6 && strlen(tok) >= 1) {
      hemiEw = tok[0];
    } else if (field == 9 && strlen(tok) == 6) {
      uint8_t d = (uint8_t)((tok[0] - '0') * 10 + (tok[1] - '0'));
      uint8_t m = (uint8_t)((tok[2] - '0') * 10 + (tok[3] - '0'));
      uint16_t y = (uint16_t)(2000 + (tok[4] - '0') * 10 + (tok[5] - '0'));
      utcDay = d;
      utcMonth = m;
      utcYear = y;
      gotDate = true;
    }
    tok = strtok(NULL, ",");
    field++;
  }

  haveTime = false;
  havePosition = false;

  if (status == 'A' && gotTime && gotDate) {
    haveTime = true;
  }

  if (status == 'A' && latStr[0] && lonStr[0]) {
    gpsLatDeg = nmeaCoordToDegLat(latStr, hemiNs);
    gpsLonDeg = nmeaCoordToDegLon(lonStr, hemiEw);
    havePosition = true;
  }

  return haveTime;
}

static uint16_t dayOfYear(uint16_t y, uint8_t m, uint8_t d) {
  static const uint8_t mdays[] = { 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 };
  bool leap = (y % 4 == 0 && y % 100 != 0) || (y % 400 == 0);
  uint16_t doy = d;
  for (uint8_t i = 1; i < m; i++) {
    doy += mdays[i - 1];
    if (i == 2 && leap) doy += 1;
  }
  return doy;
}

static uint16_t packedUtcDay() {
  uint8_t yy = (uint8_t)(utcYear % 100);
  uint16_t doy = dayOfYear(utcYear, utcMonth, utcDay);
  return ((uint16_t)yy << 9) | (doy & 0x1FFU);
}

static bool alreadyTransmittedToday(uint16_t pack) {
  uint16_t v = 0;
  EEPROM.get(EEPROM_ADDR_LAST_TX_DAY, v);
  return v == pack;
}

static void markTransmittedToday(uint16_t pack) {
  EEPROM.put(EEPROM_ADDR_LAST_TX_DAY, pack);
}

static bool inMorningWindowUTC() {
  if (DEBUG_FORCE_TX) return true;
  if (MORNING_START_UTC_HOUR < MORNING_END_UTC_HOUR) {
    return utcHour >= MORNING_START_UTC_HOUR && utcHour < MORNING_END_UTC_HOUR;
  }
  return utcHour >= MORNING_START_UTC_HOUR || utcHour < MORNING_END_UTC_HOUR;
}

static void acquireGpsRmc(unsigned long timeoutMs) {
  haveTime = false;
  havePosition = false;
  unsigned long t0 = millis();
  char line[100];
  uint8_t li = 0;

  while ((unsigned long)(millis() - t0) < timeoutMs) {
    while (gpsSerial.available()) {
      char c = (char)gpsSerial.read();
      if (c == '\r') continue;
      if (c == '\n') {
        line[li] = '\0';
        li = 0;
        Serial.println(F("Parse line"));
        Serial.println(line);
        if (parseRMC(line) && haveTime) return;
        continue;
      }
      if (li < sizeof(line) - 1) line[li++] = c;
    }
  }
}

// ---------------------------------------------------------------------------

void setup() {
  Serial.begin(9600);
  gpsSerial.begin(GPS_BAUD);
    Serial.println(F("1"));

  Wire.begin();
     Serial.println(F("2"));
 if (clockgen.begin() != ERROR_NONE) {
    si5351Ok = false;
    Serial.println(F("Si5351 not found"));
  } else {
    si5351Ok = true;
    clockgen.enableOutputs(false);
  }
     Serial.println(F("3"));

  acquireGpsRmc(120000UL);
     Serial.println(F("4"));

  if (!haveTime) {
    Serial.println(F("No GPS time fix (RMC) — check antenna/sky view."));
  } else {
    Serial.print(F("UTC "));
    Serial.print(utcYear);
    Serial.print('-');
    Serial.print(utcMonth);
    Serial.print('-');
    Serial.print(utcDay);
    Serial.print(' ');
    Serial.print(utcHour);
    Serial.print(':');
    Serial.print(utcMinute);
    Serial.print(':');
    Serial.println(utcSecond);
    if (havePosition) {
      Serial.print(F("Lat "));
      Serial.print(gpsLatDeg, 5);
      Serial.print(F(" Lon "));
      Serial.println(gpsLonDeg, 5);
    }
  }

  bool shouldTx = false;
  if (haveTime) {
    uint16_t pack = packedUtcDay();
    if (DEBUG_FORCE_TX) {
      shouldTx = true;
    } else if (inMorningWindowUTC() && !alreadyTransmittedToday(pack)) {
      shouldTx = true;
    }
  } else if (DEBUG_FORCE_TX) {
    shouldTx = true;
  }

  char grid4[5] = "AA00";
  if (havePosition) {
    char grid6[7];
    jtencode.latlon_to_grid(gpsLatDeg, gpsLonDeg, grid6);
    memcpy(grid4, grid6, 4);
    grid4[4] = '\0';
  } else {
    memcpy(grid4, GRID_STATIC, 5);
  }

  if (shouldTx && si5351Ok) {
    Serial.println(F("WSPR TX"));
    sendWsprPacket(CALLSIGN, grid4, WSPR_POWER_DBM);

    if (haveTime && !DEBUG_FORCE_TX) {
      markTransmittedToday(packedUtcDay());
    }
  }

  if (si5351Ok) clockgen.enableOutputs(false);

  Serial.println(F("Cycle complete; holding idle."));
}

void loop() {

  // 1. Try to acquire a fresh GPS fix (timeout after 10 seconds)
  // This updates utcHour, utcMinute, and position data
  acquireGpsRmc(10000UL);

  if (haveTime) {
    uint16_t currentDayPack = packedUtcDay();

    // 2. Check if we are in the TX window AND haven't sent today yet
    if (inMorningWindowUTC() && !alreadyTransmittedToday(currentDayPack)) {

      // Determine Grid (Current GPS position or Static fallback)
      char grid4[5];
      if (havePosition) {
        char grid6[7];
        jtencode.latlon_to_grid(gpsLatDeg, gpsLonDeg, grid6);
        strncpy(grid4, grid6, 4);
        grid4[4] = '\0';
      } else {
        strcpy(grid4, GRID_STATIC);
      }

      // 3. Perform the WSPR Transmission
      if (si5351Ok) {
        Serial.print(F("Starting WSPR TX at UTC: "));
        Serial.print(utcHour);
        Serial.print(':');
        Serial.println(utcMinute);

        sendWsprPacket(CALLSIGN, grid4, WSPR_POWER_DBM);

        // 4. Mark today as "Done" in EEPROM
        markTransmittedToday(currentDayPack);
        Serial.println(F("TX Complete."));
      }
    }
  }

  // 5. Short sleep before next GPS poll to save power
  // (though on a Nano, power savings are minimal without deep sleep)
  delay(30000);
}
